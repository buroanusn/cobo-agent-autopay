NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL="file:./dev.db"
STORAGE_DRIVER=prisma
CHAIN_ENV=base-mainnet

# Real environment uses CAW HTTP/CLI paths. Mock requires CAW_ALLOW_MOCK=true.
CAW_MODE=http
# Official Cobo Agentic Wallet SDK names. Required when CAW_MODE=http.
AGENT_WALLET_API_URL=
AGENT_WALLET_API_KEY=
AGENT_WALLET_WALLET_ID=
# Optional override. Defaults to BASE_ETH when CHAIN_ENV=base-mainnet.
CAW_CHAIN_ID=BASE_ETH
CAW_FAUCET_TOKEN_ID=

# CAW CLI onboarding. Each app user gets an isolated HOME under this root.
CAW_CLI_PATH=
CAW_CLI_HOME_ROOT=.caw-cli-homes

# Legacy aliases kept for compatibility with the first MVP adapter.
CAW_API_BASE_URL=
CAW_API_KEY=
CAW_WALLET_ID=
CAW_WALLET_ADDRESS=
CAW_PACT_API_KEY=
CAW_CONNECT_PATH=/v1/wallets/connect
CAW_CREATE_PAIRING_CODE_PATH=/v1/pairing-codes
CAW_CREATE_PACT_PATH=/v1/pacts
CAW_EXECUTE_PURCHASE_PATH=/v1/pacts/execute-contract-call

# Real Base mainnet by default. Use real ETH for gas and real USDC for payments.
BASE_RPC_URL=
DEPLOYER_PRIVATE_KEY=
USDC_ADDRESS=
PAYMENT_CONTRACT_ADDRESS=
TREASURY_ADDRESS=
CREDITS_PER_USDC=1000

# Venice AI. x402 top-up uses real Base mainnet USDC.
VENICE_BASE_URL=https://api.venice.ai
VENICE_API_KEY=
VENICE_INFERENCE_MODEL=llama-3.3-70b
VENICE_X402_DEFAULT_USDC_MINOR=1000000

# Optional Pact drafter. Without OPENAI_API_KEY, the app uses the deterministic
# local drafter and still submits a valid CAW PactSpec.
OPENAI_API_KEY=
PACT_DRAFTER_MODE=deterministic
PACT_DRAFTER_MODEL=gpt-4.1-mini
