NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL="postgresql://agent_to_token:agent_to_token@localhost:5432/agent_to_token?schema=public"
STORAGE_DRIVER=memory
CHAIN_ENV=base-sepolia

# mock keeps the full product flow runnable without CAW credentials.
# Set to http when wiring a real CAW API gateway.
CAW_MODE=mock
# Official Cobo Agentic Wallet SDK names. Required when CAW_MODE=http.
AGENT_WALLET_API_URL=
AGENT_WALLET_API_KEY=
AGENT_WALLET_WALLET_ID=
# Optional override. Defaults to TBASE_SETH when CHAIN_ENV=base-sepolia.
CAW_CHAIN_ID=TBASE_SETH
CAW_FAUCET_TOKEN_ID=BASE_SEPOLIA_USDC

# Legacy aliases kept for compatibility with the first MVP adapter.
CAW_API_BASE_URL=
CAW_API_KEY=
CAW_WALLET_ID=
CAW_WALLET_ADDRESS=
CAW_PACT_API_KEY=
CAW_CONNECT_PATH=/v1/wallets/connect
CAW_CREATE_PAIRING_CODE_PATH=/v1/pairing-codes
CAW_CREATE_PACT_PATH=/v1/pacts
CAW_EXECUTE_PURCHASE_PATH=/v1/pacts/execute-contract-call

# Base Sepolia testnet by default. Use Base Sepolia ETH + test USDC for demos.
BASE_RPC_URL=
DEPLOYER_PRIVATE_KEY=
USDC_ADDRESS=
PAYMENT_CONTRACT_ADDRESS=
TREASURY_ADDRESS=
CREDITS_PER_USDC=1000

# Optional Pact drafter. Without OPENAI_API_KEY, the app uses the deterministic
# local drafter and still submits a valid CAW PactSpec.
OPENAI_API_KEY=
PACT_DRAFTER_MODE=deterministic
PACT_DRAFTER_MODEL=gpt-4.1-mini
