generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum CawAuthorizationStatus {
  pending_user_approval
  active
  expired
  revoked
}

enum CawAuthorizationPurpose {
  credits_payment
  venice_x402
  blockrun_x402
}

enum TopupOrderStatus {
  pending_policy
  caw_submitted
  chain_pending
  pending_approval
  approval_expired
  credited
  failed
}

enum AgentUsageStatus {
  completed
  failed_insufficient_balance
}

enum AgentStatus {
  active
  paused
  disabled
}

enum AgentRunStatus {
  running
  waiting_for_venice_balance
  completed
  failed
}

enum VeniceTopupOrderStatus {
  pending_policy
  caw_submitted
  payment_submitted
  payment_failed
  balance_pending
  balance_confirmed
  failed
}

enum LedgerEntryType {
  opening_grant
  agent_usage
  auto_topup
}

enum CawPairingStatus {
  generated
  paired
  expired
}

enum CawOnboardingStatus {
  not_started
  waiting_input
  running
  wallet_active
  failed
}

model User {
  id                   String                       @id
  email                String                       @unique
  coboId               String?                      @unique
  coboIdBoundAt        DateTime?
  cawWalletId          String?                      @unique
  cawWalletAddress     String?                      @unique
  createdAt            DateTime                     @default(now())
  creditAccount        CreditAccount?
  authorizations       CawAuthorization[]
  pairingSession       CawPairingSession?
  cawOnboardingSession CawWalletOnboardingSession?
  cawRuntimeCredential CawRuntimeCredential?
  ledgerEntries        LedgerEntry[]
  topupOrders          TopupOrder[]
  veniceTopupOrders    VeniceTopupOrder[]
  usageEvents          AgentUsageEvent[]
  agents               Agent[]
  agentRuns            AgentRun[]

  @@map("users")
}

model CawPairingSession {
  userId    String           @id
  code      String
  status    CawPairingStatus
  expiresAt DateTime
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("caw_pairing_sessions")
}

model CawWalletOnboardingSession {
  userId       String              @id
  sessionId    String?
  status       CawOnboardingStatus
  phase        String?
  walletStatus String?
  needsInput   Boolean             @default(false)
  prompts      String?
  nextAction   String?
  lastError    String?
  agentName    String?
  apiUrl       String?
  walletId     String?
  walletName   String?
  agentId      String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("caw_wallet_onboarding_sessions")
}

model CawRuntimeCredential {
  id              String    @id
  userId          String    @unique
  walletId        String    @unique
  walletAddress   String    @unique
  walletName      String?
  agentId         String
  apiUrl          String
  apiKeyEncrypted String
  cawHomePath     String?
  keyVersion      Int       @default(1)
  lastVerifiedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@map("caw_runtime_credentials")
}

model CreditAccount {
  userId                     String   @id
  balanceCredits             Int
  lowBalanceThresholdCredits Int
  autoTopupCredits           Int
  updatedAt                  DateTime @updatedAt
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_accounts")
}

model Agent {
  id                  String       @id
  userId              String
  name                String
  status              AgentStatus  @default(active)
  veniceAutoTopup     Boolean      @default(true)
  veniceTopupUsdMinor Int          @default(1000000)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs                AgentRun[]
  veniceTopupOrders   VeniceTopupOrder[]

  @@unique([userId, name])
  @@index([userId, status])
  @@map("agents")
}

model AgentRun {
  id                    String          @id
  userId                String
  agentId               String
  taskName              String
  prompt                String
  status                AgentRunStatus
  resumeAfterOrderId    String?
  lastError             String?
  startedAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  completedAt           DateTime?
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent                 Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  resumeAfterOrder      VeniceTopupOrder? @relation("AgentRunResumeOrder", fields: [resumeAfterOrderId], references: [id], onDelete: SetNull)
  veniceTopupOrders     VeniceTopupOrder[]

  @@index([userId, agentId, status])
  @@index([resumeAfterOrderId])
  @@map("agent_runs")
}

model VeniceTopupOrder {
  id                  String                  @id
  userId              String
  agentId             String?
  agentRunId          String?
  walletAddress       String
  pactId              String
  status              VeniceTopupOrderStatus
  usdAmount           Float
  amountUsdcMinor     Int
  responseStatus      Int?
  responseBodyPreview String?
  txHash              String?
  balanceCanConsume   Boolean?
  balanceUsd          Float?
  failureReason       String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  paymentSubmittedAt  DateTime?
  balanceCheckedAt    DateTime?
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent               Agent?                  @relation(fields: [agentId], references: [id], onDelete: SetNull)
  agentRun            AgentRun?               @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  resumeForRuns       AgentRun[]              @relation("AgentRunResumeOrder")

  @@index([userId, status])
  @@index([userId, agentId, status])
  @@index([agentRunId])
  @@map("venice_topup_orders")
}

model CawAuthorization {
  id                    String                 @id
  userId                String
  purpose               CawAuthorizationPurpose @default(credits_payment)
  walletAddress         String
  pactId                String
  pactApiKey            String?
  status                CawAuthorizationStatus
  singleLimitUsdcMinor  Int
  dailyLimitUsdcMinor   Int
  monthlyLimitUsdcMinor Int
  spentTodayUsdcMinor   Int                    @default(0)
  spentMonthUsdcMinor   Int                    @default(0)
  dailyWindowStart      DateTime
  monthlyWindowStart    DateTime
  expiresAt             DateTime
  createdAt             DateTime               @default(now())
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, purpose, createdAt])
  @@map("caw_authorizations")
}

model LedgerEntry {
  id                  String          @id
  userId              String
  type                LedgerEntryType
  creditsDelta        Int
  balanceAfterCredits Int
  orderId             String?
  usageEventId        String?
  usdcMinor           Int?
  txHash              String?
  createdAt           DateTime        @default(now())
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([orderId])
  @@index([usageEventId])
  @@map("ledger_entries")
}

model TopupOrder {
  id              String           @id
  userId          String
  walletAddress   String
  status          TopupOrderStatus
  reason          String
  orderId         String           @unique
  onchainOrderId  String           @unique
  amountUsdcMinor Int
  credits         Int
  txHash          String?
  failureReason   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  creditedAt      DateTime?
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([createdAt])
  @@map("topup_orders")
}

model AgentUsageEvent {
  id               String           @id
  userId           String
  taskName         String
  prompt           String
  estimatedCredits Int
  creditsCharged   Int
  inputTokens      Int?
  outputTokens     Int?
  modelId          String?
  priceVersion     String?
  status           AgentUsageStatus
  createdAt        DateTime         @default(now())
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("agent_usage_events")
}

model ChainEventSeen {
  eventId     String   @id
  txHash      String?
  logIndex    Int?
  orderId     String?
  processedAt DateTime @default(now())

  @@index([txHash, logIndex])
  @@index([orderId])
  @@map("chain_events_seen")
}
