generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CawAuthorizationStatus {
  pending_user_approval
  active
  expired
  revoked
}

enum TopupOrderStatus {
  pending_policy
  caw_submitted
  chain_pending
  pending_approval
  approval_expired
  credited
  failed
}

enum AgentUsageStatus {
  completed
  failed_insufficient_balance
}

enum LedgerEntryType {
  opening_grant
  agent_usage
  auto_topup
}

enum CawPairingStatus {
  generated
  paired
  expired
}

enum CawOnboardingStatus {
  not_started
  waiting_input
  running
  wallet_active
  failed
}

model User {
  id                   String                       @id
  email                String                       @unique
  cawWalletId          String?                      @unique
  cawWalletAddress     String?                      @unique
  createdAt            DateTime                     @default(now())
  creditAccount        CreditAccount?
  authorizations       CawAuthorization[]
  pairingSession       CawPairingSession?
  cawOnboardingSession CawWalletOnboardingSession?
  ledgerEntries        LedgerEntry[]
  topupOrders          TopupOrder[]
  usageEvents          AgentUsageEvent[]

  @@map("users")
}

model CawPairingSession {
  userId    String           @id
  code      String
  status    CawPairingStatus
  expiresAt DateTime
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("caw_pairing_sessions")
}

model CawWalletOnboardingSession {
  userId       String              @id
  sessionId    String?
  status       CawOnboardingStatus
  phase        String?
  walletStatus String?
  needsInput   Boolean             @default(false)
  prompts      Json?
  nextAction   String?
  lastError    String?
  agentName    String?
  apiUrl       String?
  walletId     String?
  walletName   String?
  agentId      String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("caw_wallet_onboarding_sessions")
}

model CreditAccount {
  userId                     String   @id
  balanceCredits             Int
  lowBalanceThresholdCredits Int
  autoTopupCredits           Int
  updatedAt                  DateTime @updatedAt
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_accounts")
}

model CawAuthorization {
  id                    String                 @id
  userId                String
  walletAddress         String
  pactId                String
  pactApiKey            String?
  status                CawAuthorizationStatus
  singleLimitUsdcMinor  Int
  dailyLimitUsdcMinor   Int
  monthlyLimitUsdcMinor Int
  spentTodayUsdcMinor   Int                    @default(0)
  spentMonthUsdcMinor   Int                    @default(0)
  dailyWindowStart      DateTime
  monthlyWindowStart    DateTime
  expiresAt             DateTime
  createdAt             DateTime               @default(now())
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("caw_authorizations")
}

model LedgerEntry {
  id                  String          @id
  userId              String
  type                LedgerEntryType
  creditsDelta        Int
  balanceAfterCredits Int
  orderId             String?
  usageEventId        String?
  usdcMinor           Int?
  txHash              String?
  createdAt           DateTime        @default(now())
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([orderId])
  @@index([usageEventId])
  @@map("ledger_entries")
}

model TopupOrder {
  id              String           @id
  userId          String
  walletAddress   String
  status          TopupOrderStatus
  reason          String
  orderId         String           @unique
  onchainOrderId  String           @unique
  amountUsdcMinor Int
  credits         Int
  txHash          String?
  failureReason   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  creditedAt      DateTime?
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([createdAt])
  @@map("topup_orders")
}

model AgentUsageEvent {
  id               String           @id
  userId           String
  taskName         String
  prompt           String
  estimatedCredits Int
  creditsCharged   Int
  inputTokens      Int?
  outputTokens     Int?
  modelId          String?
  priceVersion     String?
  status           AgentUsageStatus
  createdAt        DateTime         @default(now())
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("agent_usage_events")
}

model ChainEventSeen {
  eventId     String   @id
  txHash      String?
  logIndex    Int?
  orderId     String?
  processedAt DateTime @default(now())

  @@index([txHash, logIndex])
  @@index([orderId])
  @@map("chain_events_seen")
}
